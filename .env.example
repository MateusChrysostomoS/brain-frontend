# PreCheck API base URL. Empty = same-origin/relative.
# Used by lib/api.ts for the existing PreCheck dashboard calls.
NEXT_PUBLIC_API_URL=

# brain-api base URL (login + /auth/me + entitlements + demo-requests).
# Used by lib/manage-api.ts. REQUIRED in production — set to the deployed brain-api
# origin (no trailing slash), e.g. https://brain-api.<your-easypanel-host>.
# Empty makes calls same-origin and they will NOT reach brain-api.
NEXT_PUBLIC_MANAGE_API_BASE_URL=
